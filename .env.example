# OpenRouter (chat) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Comma-separated backups if primary times out (504) or is unavailable
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o-mini,google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
# Daily token budget for admin dashboard (in-process counter)
DAILY_TOKEN_LIMIT=100000

# MongoDB (optional; mock DB used if unreachable)
MONGODB_URL=mongodb://localhost:27017

# JWT (change in production)
SECRET_KEY=change-me-in-production
